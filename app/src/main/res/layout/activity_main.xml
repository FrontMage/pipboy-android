<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/rootRow"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="horizontal"
  android:background="#1B1410">

  <LinearLayout
    android:id="@+id/sideNav"
    android:layout_width="132dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#2A1F18">

    <TextView
      android:id="@+id/navHeaderText"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="NAVIGATION"
      android:textColor="#CCB081"
      android:textStyle="bold"
      android:textSize="13sp" />

    <Button
      android:id="@+id/navMapBtn"
      android:layout_width="match_parent"
      android:layout_height="56dp"
      android:layout_marginTop="10dp"
      android:background="@drawable/nav_item_bg"
      android:backgroundTint="@null"
      android:textColor="@color/nav_item_text"
      android:textAllCaps="true"
      android:textStyle="bold"
      android:text="MAP" />

    <Button
      android:id="@+id/navBagBtn"
      android:layout_width="match_parent"
      android:layout_height="56dp"
      android:layout_marginTop="8dp"
      android:background="@drawable/nav_item_bg"
      android:backgroundTint="@null"
      android:textColor="@color/nav_item_text"
      android:textAllCaps="true"
      android:textStyle="bold"
      android:text="BAG" />

    <Button
      android:id="@+id/navImeBtn"
      android:layout_width="match_parent"
      android:layout_height="56dp"
      android:layout_marginTop="8dp"
      android:background="@drawable/nav_item_bg"
      android:backgroundTint="@null"
      android:textColor="@color/nav_item_text"
      android:textAllCaps="true"
      android:textStyle="bold"
      android:text="IME" />

    <Button
      android:id="@+id/navDebugBtn"
      android:layout_width="match_parent"
      android:layout_height="56dp"
      android:layout_marginTop="8dp"
      android:background="@drawable/nav_item_bg"
      android:backgroundTint="@null"
      android:textColor="@color/nav_item_text"
      android:textAllCaps="true"
      android:textStyle="bold"
      android:text="DEBUG" />

    <Button
      android:id="@+id/navConfigBtn"
      android:layout_width="match_parent"
      android:layout_height="56dp"
      android:layout_marginTop="8dp"
      android:background="@drawable/nav_item_bg"
      android:backgroundTint="@null"
      android:textColor="@color/nav_item_text"
      android:textAllCaps="true"
      android:textStyle="bold"
      android:text="CONFIG" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/mainColumn"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:paddingStart="4dp"
      android:paddingEnd="4dp">

      <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="TurtleWoW Companion"
        android:textColor="#E8D6B4"
        android:textStyle="bold"
        android:textSize="18sp" />

      <TextView
        android:id="@+id/connStateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Idle"
        android:textColor="#D5BB8A"
        android:textSize="13sp" />
    </LinearLayout>

    <FrameLayout
      android:id="@+id/pageContainer"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:layout_marginTop="6dp"
      android:background="#241A14">

      <LinearLayout
        android:id="@+id/pageMap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="4dp">

        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:orientation="vertical">

          <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Idle"
            android:textStyle="bold"
            android:textColor="#E8D6B4" />

          <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="6dp"
            android:background="#111111">

            <com.turtlewow.pipboy.MapSurfaceView
              android:id="@+id/mapView"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:background="#111111" />
          </FrameLayout>
        </LinearLayout>

        <LinearLayout
          android:id="@+id/playerPanel"
          android:layout_width="152dp"
          android:layout_height="match_parent"
          android:layout_marginStart="4dp"
          android:orientation="vertical"
          android:padding="6dp"
          android:background="#2C2119">

          <TextView
            android:id="@+id/playerPanelTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PLAYER"
            android:textColor="#D7BD8C"
            android:textStyle="bold"
            android:textSize="12sp" />

          <TextView
            android:id="@+id/playerNameLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Name"
            android:textColor="#E7D3AD"
            android:textSize="13sp" />

          <TextView
            android:id="@+id/playerNameValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#F4E6C8"
            android:textStyle="bold"
            android:textSize="20sp" />

          <TextView
            android:id="@+id/playerLevelLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Level"
            android:textColor="#E7D3AD"
            android:textSize="13sp" />

          <TextView
            android:id="@+id/playerLevelValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#F4E6C8"
            android:textStyle="bold"
            android:textSize="22sp" />

          <TextView
            android:id="@+id/playerHpLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="HP"
            android:textColor="#E7D3AD"
            android:textSize="13sp" />

          <TextView
            android:id="@+id/playerHpValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#F4E6C8"
            android:textStyle="bold"
            android:textSize="18sp" />

          <TextView
            android:id="@+id/playerZoneLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Zone"
            android:textColor="#E7D3AD"
            android:textSize="13sp" />

          <TextView
            android:id="@+id/playerZoneValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#F4E6C8"
            android:textStyle="bold"
            android:textSize="16sp" />

          <TextView
            android:id="@+id/playerCoordsLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Coords"
            android:textColor="#E7D3AD"
            android:textSize="13sp" />

          <TextView
            android:id="@+id/playerCoordsValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#F4E6C8"
            android:textStyle="bold"
            android:textSize="16sp" />
        </LinearLayout>
      </LinearLayout>

      <LinearLayout
        android:id="@+id/pageBag"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
          android:id="@+id/bagSummaryText"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="Bag: waiting data"
          android:textColor="#E8D6B4"
          android:textStyle="bold"
          android:textSize="14sp" />

        <LinearLayout
          android:id="@+id/bagFilterRow"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="8dp"
          android:orientation="horizontal">

          <Button
            android:id="@+id/bagFilterAllBtn"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:background="@drawable/nav_item_bg"
            android:backgroundTint="@null"
            android:text="ALL"
            android:textAllCaps="false"
            android:textColor="@color/nav_item_text"
            android:textSize="11sp"
            android:textStyle="bold" />

          <Button
            android:id="@+id/bagFilterUseBtn"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/nav_item_bg"
            android:backgroundTint="@null"
            android:text="USE"
            android:textAllCaps="false"
            android:textColor="@color/nav_item_text"
            android:textSize="11sp"
            android:textStyle="bold" />

          <Button
            android:id="@+id/bagFilterMatBtn"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/nav_item_bg"
            android:backgroundTint="@null"
            android:text="MAT"
            android:textAllCaps="false"
            android:textColor="@color/nav_item_text"
            android:textSize="11sp"
            android:textStyle="bold" />

          <Button
            android:id="@+id/bagFilterGearBtn"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/nav_item_bg"
            android:backgroundTint="@null"
            android:text="GEAR"
            android:textAllCaps="false"
            android:textColor="@color/nav_item_text"
            android:textSize="11sp"
            android:textStyle="bold" />

          <Button
            android:id="@+id/bagFilterOtherBtn"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/nav_item_bg"
            android:backgroundTint="@null"
            android:text="OTHER"
            android:textAllCaps="false"
            android:textColor="@color/nav_item_text"
            android:textSize="11sp"
            android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1"
          android:layout_marginTop="8dp"
          android:orientation="horizontal">

          <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/bagGrid"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="6"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:scrollbars="vertical"
            android:background="#15100D" />

          <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:layout_marginStart="8dp"
            android:background="#2C2119"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <LinearLayout
              android:id="@+id/bagDetailPanel"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:padding="6dp">

              <com.turtlewow.pipboy.SquareFrameLayout
                android:layout_width="88dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="#1A130E"
                android:padding="3dp">

                <ImageView
                  android:id="@+id/bagDetailIcon"
                  android:layout_width="match_parent"
                  android:layout_height="match_parent"
                  android:contentDescription="@null"
                  android:scaleType="centerCrop" />
              </com.turtlewow.pipboy.SquareFrameLayout>

              <TextView
                android:id="@+id/bagDetailName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxLines="2"
                android:text="-"
                android:textColor="#F4E6C8"
                android:textSize="12sp"
                android:textStyle="bold" />

              <TextView
                android:id="@+id/bagDetailType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="-"
                android:textColor="#D7BD8C"
                android:textSize="11sp" />

              <TextView
                android:id="@+id/bagDetailClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="-"
                android:textColor="#D7BD8C"
                android:textSize="11sp" />

              <TextView
                android:id="@+id/bagDetailPriceUnit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="-"
                android:textColor="#D7BD8C"
                android:textSize="11sp" />

              <TextView
                android:id="@+id/bagDetailPriceStack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="-"
                android:textColor="#D7BD8C"
                android:textSize="11sp" />

              <TextView
                android:id="@+id/bagDetailCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="-"
                android:textColor="#D7BD8C"
                android:textSize="11sp" />

              <TextView
                android:id="@+id/bagDetailPos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="-"
                android:textColor="#D7BD8C"
                android:textSize="11sp" />

              <TextView
                android:id="@+id/bagDetailId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="-"
                android:textColor="#D7BD8C"
                android:textSize="11sp" />
            </LinearLayout>
          </ScrollView>
        </LinearLayout>

        <TextView
          android:id="@+id/bagHintText"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="Tap item to view details"
          android:textColor="#A88F69"
          android:textSize="11sp" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/pageIme"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
          android:id="@+id/imeText"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="IME Bridge"
          android:textColor="#E8D6B4"
          android:textStyle="bold"
          android:textSize="18sp" />

        <EditText
          android:id="@+id/imeInput"
          android:layout_width="match_parent"
          android:layout_height="120dp"
          android:layout_marginTop="10dp"
          android:background="#15100D"
          android:gravity="top|start"
          android:hint="Type text here..."
          android:inputType="textMultiLine|textNoSuggestions"
          android:maxLines="5"
          android:padding="10dp"
          android:textColor="#F4E6C8"
          android:textColorHint="#A88F69" />

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="10dp"
          android:orientation="horizontal">

          <Button
            android:id="@+id/imeInsertBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#3A2C21"
            android:text="Insert"
            android:textColor="#E7D3AD" />

          <Button
            android:id="@+id/imeSendBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="#3A2C21"
            android:text="Insert + Send"
            android:textColor="#E7D3AD" />
        </LinearLayout>
      </LinearLayout>

      <LinearLayout
        android:id="@+id/pageDebug"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="6dp"
        android:visibility="gone">

        <TextView
          android:id="@+id/debugStatusText"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:textColor="#8FAE8F"
          android:textSize="12sp"
          android:typeface="monospace"
          android:text="debug: waiting packets" />

        <ScrollView
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1"
          android:layout_marginTop="6dp"
          android:background="#111111">

          <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:textColor="#A9F5A9"
            android:textSize="12sp"
            android:typeface="monospace" />
        </ScrollView>
      </LinearLayout>

      <LinearLayout
        android:id="@+id/pageConfig"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal">

          <EditText
            android:id="@+id/ipInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:hint="WoW IP"
            android:textColor="#E7D3AD"
            android:textColorHint="#A88F69"
            android:inputType="text"
            android:maxLines="1" />

          <EditText
            android:id="@+id/portInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:hint="Port"
            android:textColor="#E7D3AD"
            android:textColorHint="#A88F69"
            android:inputType="number"
            android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:layout_marginTop="8dp">

          <Button
            android:id="@+id/connectBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#E7D3AD"
            android:backgroundTint="#3A2C21"
            android:text="Connect" />

          <Button
            android:id="@+id/langBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:layout_marginStart="8dp"
            android:textColor="#E7D3AD"
            android:backgroundTint="#3A2C21"
            android:text="EN" />
        </LinearLayout>
      </LinearLayout>
    </FrameLayout>
  </LinearLayout>
</LinearLayout>
