<?xml version="1.0" encoding="utf-8"?>
<com.turtlewow.pipboy.SquareFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_margin="2dp"
  android:background="@drawable/bag_slot_bg"
  android:padding="2dp">

  <ImageView
    android:id="@+id/slotIcon"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:contentDescription="@null"
    android:scaleType="centerCrop" />

  <TextView
    android:id="@+id/slotCount"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|end"
    android:layout_marginEnd="3dp"
    android:layout_marginBottom="1dp"
    android:includeFontPadding="false"
    android:shadowColor="#000000"
    android:shadowDx="1"
    android:shadowDy="1"
    android:shadowRadius="0"
    android:textColor="#F4E6C8"
    android:textSize="11sp"
    android:textStyle="bold" />
</com.turtlewow.pipboy.SquareFrameLayout>
