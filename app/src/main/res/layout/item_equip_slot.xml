<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_margin="2dp"
  android:orientation="vertical">

  <com.turtlewow.pipboy.SquareFrameLayout
    android:id="@+id/equipSlotFrame"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1E1712"
    android:padding="2dp">

    <ImageView
      android:id="@+id/equipSlotIcon"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:contentDescription="@null"
      android:scaleType="centerCrop" />

    <TextView
      android:id="@+id/equipDurability"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_gravity="top|end"
      android:layout_marginTop="1dp"
      android:layout_marginEnd="2dp"
      android:includeFontPadding="false"
      android:shadowColor="#000000"
      android:shadowDx="1"
      android:shadowDy="1"
      android:shadowRadius="0"
      android:textColor="#BFEAC1"
      android:textSize="9sp"
      android:textStyle="bold"
      android:visibility="gone" />
  </com.turtlewow.pipboy.SquareFrameLayout>

  <TextView
    android:id="@+id/equipSlotName"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="3dp"
    android:ellipsize="end"
    android:gravity="center_horizontal"
    android:maxLines="1"
    android:textColor="#D7BD8C"
    android:textSize="10sp" />
</LinearLayout>
